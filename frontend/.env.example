# URL do backend (usa esta variável apenas em produção/deploy).
# Em desenvolvimento local, deixa esta variável vazia ou em branco;
# o Vite faz proxy automático de /api para http://localhost:3000 (ver vite.config.js).
#
# Em produção (Vercel, Netlify), define esta variável no dashboard do serviço:
# VITE_API_URL=https://codecheck-backend.up.railway.app

VITE_API_URL=
